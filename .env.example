# Net-Razor configuration. Copy to .env and fill in what you need.
#   cp .env.example .env

# --- Storage / runtime (optional) ---
# DATABASE_PATH=data/net_razor_audit.db
# LOG_LEVEL=INFO
# Logs go to stderr by default, which an MCP host often discards. Set LOG_FILE to
# also write them to a file you can tail (relative paths resolve to the repo root).
# LOG_FILE=logs/net-razor.log

# --- X (required for X search) ---
# Session cookies from a logged-in x.com session.
AUTH_TOKEN=
CT0=
# X search shells out to Node, located via the launching process's PATH. If your
# MCP host launches with a sparse PATH, set an absolute path so node is always found:
# NODE_BINARY=/opt/homebrew/bin/node

# --- Hacker News (no auth required) ---
# HN_ALGOLIA_BASE_URL=https://hn.algolia.com/api/v1

# --- YouTube ---
# YOUTUBE_API_KEY is required only for yt_search (query search). The channel digest and
# transcript fetch are key-free (public RSS + transcript endpoints).
YOUTUBE_API_KEY=
YT_SEARCH_MODE=broad
# Comma/newline-separated channels for yt_channel_digest (and YT_SEARCH_MODE=channels).
# Each entry may be a channel ID (UC...), an @handle, or a channel URL, and may carry
# per-channel overrides after a pipe, e.g.:  @Fireship | videos=10 days=14
YOUTUBE_CHANNEL_IDS=
# Proxy for the unauthenticated RSS + transcript fetches (a residential proxy avoids
# IP blocks). Accepts YT_PROXY_URL or the older YT_TRANSCRIPT_PROXY_URL.
# YT_PROXY_URL=
# Default for the channel digest's cross-run dedup (skip videos seen in prior runs).
# Set true for a scheduled daily digest; a call's own only_new argument overrides it.
# YT_DIGEST_ONLY_NEW=false
# Default for skipping videos with no fetchable transcript (e.g. captions disabled)
# instead of returning the description as a fallback. A call's own argument overrides it.
# YT_DIGEST_REQUIRE_TRANSCRIPT=false
# Max transcript characters returned per video (0 = no cap). ~40000 (~10k tokens)
# covers a ~35-minute video; longer ones are truncated and flagged. Bounds LLM context.
# YT_MAX_TRANSCRIPT_CHARS=40000

# --- Shared ---
# REQUEST_TIMEOUT_SECONDS=30
